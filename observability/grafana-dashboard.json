{
  "dashboard": {
    "title": "Distributed Message Queue",
    "uid": "distributed-queue",
    "panels": [
      {
        "title": "Messages Produced",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(dmq_messages_produced_total[5m])",
            "legendFormat": "{{topic}}"
          }
        ]
      },
      {
        "title": "Messages Consumed",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(dmq_messages_consumed_total[5m])",
            "legendFormat": "{{topic}}"
          }
        ]
      },
      {
        "title": "Processing Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmq_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(dmq_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Queue Depth",
        "type": "graph",
        "targets": [
          {
            "expr": "dmq_queue_depth",
            "legendFormat": "{{topic}}"
          }
        ]
      },
      {
        "title": "Failed Messages",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(dmq_messages_failed_total[5m])",
            "legendFormat": "{{topic}}"
          }
        ]
      },
      {
        "title": "Dead Letter Queue Size",
        "type": "stat",
        "targets": [
          {
            "expr": "dmq_dlq_size",
            "legendFormat": "{{topic}}"
          }
        ]
      },
      {
        "title": "Retry Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(dmq_retries_total[5m])",
            "legendFormat": "{{topic}}"
          }
        ]
      }
    ]
  }
}
