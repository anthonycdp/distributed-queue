# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue Configuration
QUEUE_PREFIX=dmq
MAX_CONCURRENCY=5
DEFAULT_RETRY_ATTEMPTS=3
DEFAULT_BACKOFF_DELAY=1000

# Dead Letter Queue
DLQ_MAX_AGE_DAYS=7
DLQ_MAX_SIZE=10000

# Observability
LOG_LEVEL=info
METRICS_PORT=9091
TRACING_ENABLED=true
TRACING_ENDPOINT=localhost:4317

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
